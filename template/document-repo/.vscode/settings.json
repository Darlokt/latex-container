{
  "latex-workshop.latex.outDir": "%DIR%/build",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (safe default)",
      "tools": ["latexmk"]
    },
    {
      "name": "latexmk (shell escape)",
      "tools": ["latexmk-shell-escape"]
    },
    {
      "name": "latexmk (LuaLaTeX)",
      "tools": ["latexmk-lualatex"]
    },
    {
      "name": "latexmk (XeLaTeX)",
      "tools": ["latexmk-xelatex"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-cd",
        "-pdf",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-halt-on-error",
        "-file-line-error",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ]
    },
    {
      "name": "latexmk-shell-escape",
      "command": "latexmk",
      "args": [
        "-cd",
        "-pdf",
        "-shell-escape",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-halt-on-error",
        "-file-line-error",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ]
    },
    {
      "name": "latexmk-lualatex",
      "command": "latexmk",
      "args": [
        "-cd",
        "-lualatex",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-halt-on-error",
        "-file-line-error",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ]
    },
    {
      "name": "latexmk-xelatex",
      "command": "latexmk",
      "args": [
        "-cd",
        "-xelatex",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-halt-on-error",
        "-file-line-error",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.formatting.latex": "latexindent",
  "latex-workshop.view.pdf.viewer": "tab",
  "cSpell.language": "en,de-de",
  "cSpell.enabledLanguageIds": ["bibtex", "latex", "markdown", "plaintext"],
  "cSpell.customDictionaries": {
    "project-words": {
      "name": "project-words",
      "path": "${workspaceFolder}/project-words.txt",
      "addWords": true
    }
  },
  "ltex.language": "en-US"
}
